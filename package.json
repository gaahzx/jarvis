{
  "name": "jarvis-voice-assistant",
  "version": "4.0.0",
  "description": "JARVIS - Iron Man Voice Assistant with Claude AI",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "jarvis": "node server.js",
    "start": "node server.js",
    "app": "electron .",
    "build-app": "electron-builder --mac"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "html2pdf.js": "^0.14.0",
    "multer": "^1.4.5-lts.1",
    "obs-websocket-js": "^5.0.8",
    "openai": "^4.0.0",
    "pdfkit": "^0.18.0",
    "puppeteer": "^24.40.0"
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.jarvis.assistant",
    "productName": "JARVIS",
    "icon": "assets/icon.png",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "darkModeSupport": true
    },
    "files": [
      "electron-main.cjs",
      "server.js",
      "public/**/*",
      "system/**/*",
      "assets/**/*",
      ".env",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/puppeteer/.local-chromium/**/*"
    ]
  }
}
